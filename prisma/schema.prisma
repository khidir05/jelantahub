generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  mitra
  nasabah
  admin
  pengepul
}

enum DeviceStatus {
  offline
  online
}

enum DeviceProcess {
  disconnect
  standby
  load
}

enum JerigenStatus {
  empty
  available
  full
}

model User {
  id_user    String   @id @default(uuid())
  name       String   @db.VarChar(40)
  username   String   @unique @db.VarChar(20)
  no_telp    String?  @db.VarChar(15)
  password   String   @db.VarChar(100)
  role       Role
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  points       Point?
  devices      Device[]     @relation("MitraDevices")
  pickup_logs  PickupLog[]  @relation("PengepulLogs")
  oil_deposits OilDeposit[] @relation("NasabahDeposits")
  notifications Notification[]

  items           Item[]          @relation("MitraItems")
  point_exchanges PointExchange[] @relation("NasabahExchanges")

  @@map("users")
}

model Point {
  id_nasabah String   @id
  balance    Int      @default(0)
  updated_at DateTime @updatedAt

  user User @relation(fields: [id_nasabah], references: [id_user], onDelete: Cascade)

  @@map("points")
}

model Device {
  id_device     String        @id @default(uuid())
  device_code   String        @unique @db.VarChar(10)
  location_name String        @db.VarChar(15)
  address       String?       @db.Text
  status        DeviceStatus  
  process       DeviceProcess @default(disconnect)
  id_mitra      String
  id_nasabah    String?       @db.VarChar(50)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  mitra        User         @relation("MitraDevices", fields: [id_mitra], references: [id_user])
  jerigens     Jerigen[]
  pickup_logs  PickupLog[]
  oil_deposits OilDeposit[]

  @@map("devices")
}

model SensorRead {
  id_read   String  @id @default(uuid())
  volume    Int
  quality   Int
  jerigen_a Int?
  jerigen_b Int?

  oil_deposits OilDeposit[]

  @@map("sensor_reads")
}

model Jerigen {
  id_jerigen        String        @id @default(uuid())
  jerigen_code      String        @unique @db.VarChar(15)
  id_device         String
  max_capacity      Int
  current_volume    Int           @default(0)
  status            JerigenStatus @default(empty)
  last_collected_at DateTime?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  device      Device      @relation(fields: [id_device], references: [id_device])
  pickup_logs PickupLog[]

  @@map("jerigens")
}

model PickupLog {
  id_pickup     String   @id @default(uuid())
  jerigen_code  String
  id_device     String
  id_pengepul   String
  volume_before Int
  volume_taken  Int
  created_at    DateTime @default(now())

  jerigen  Jerigen @relation(fields: [jerigen_code], references: [jerigen_code])
  device   Device  @relation(fields: [id_device], references: [id_device])
  pengepul User    @relation("PengepulLogs", fields: [id_pengepul], references: [id_user])

  @@map("pickup_logs")
}

model OilDeposit {
  id_deposit    String   @id @default(uuid())
  id_read       String?
  id_device     String
  id_nasabah    String
  volume        Int
  quality_score Int
  point_earned  Int
  created_at    DateTime @default(now())

  sensor_read SensorRead? @relation(fields: [id_read], references: [id_read])
  device      Device      @relation(fields: [id_device], references: [id_device])
  nasabah     User        @relation("NasabahDeposits", fields: [id_nasabah], references: [id_user])

  @@map("oil_deposits")
}

model PointRule {
  id_rule         Int       @id @default(autoincrement())
  quality         String    @db.VarChar(10)
  point_per_liter Int
  is_active       Boolean   @default(true)

  @@map("point_rules")
}

enum NotificationType {
  info
  success
  warning
  alert
}

model Notification {
  id_notification BigInt            @id @default(autoincrement())
  id_user         String
  title           String?           @db.VarChar(255)
  message         String?           @db.Text
  type            NotificationType?
  is_read         Boolean           @default(false)
  read_at         DateTime?
  link            String?           @db.VarChar(255)
  
  ref_table       String?           @db.VarChar(100)
  ref_id          String?           @db.VarChar(100)

  created_at      DateTime          @default(now())
  updated_at      DateTime          @default(now()) @updatedAt

  user            User              @relation(fields: [id_user], references: [id_user], onDelete: Cascade)

  @@map("notifications")
}

enum ExchangeStatus {
  pending
  completed
  cancelled
}

model Item {
  id_item     String   @id @default(uuid()) // UUID/CUID
  id_mitra    String
  item_name   String   @db.VarChar(20)
  description String   @db.Text
  point_cost  Int
  stock       Int
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  mitra       User            @relation("MitraItems", fields: [id_mitra], references: [id_user])
  exchanges   PointExchange[]

  @@map("items")
}

model PointExchange {
  id_exchange       String         @id @default(uuid()) // UUID/CUID
  id_nasabah        String
  id_item           String
  quantity          Int
  total_points_used Int
  status            ExchangeStatus @default(pending)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt

  nasabah User @relation("NasabahExchanges", fields: [id_nasabah], references: [id_user])
  item    Item @relation(fields: [id_item], references: [id_item])

  @@map("point_exchanges")
}